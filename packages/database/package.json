{
  "name": "@smc/database",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "generate": "prisma generate --schema ../../prisma/schema.prisma",
    "validate": "prisma validate --schema ../../prisma/schema.prisma",
    "migrate": "prisma migrate dev --schema ../../prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema ../../prisma/schema.prisma",
    "seed": "tsx ../../prisma/seed/index.ts",
    "studio": "prisma studio --schema ../../prisma/schema.prisma",
    "build": "tsup src/index.ts --format cjs --dts --clean --sourcemap && test -f dist/index.d.ts",
    "typecheck": "tsc --noEmit -p .",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  },
  "devDependencies": {
    "prisma": "5.22.0",
    "tsx": "^4.19.1",
    "@smc/config-typescript": "workspace:*",
    "typescript": "^5.6.3",
    "tsup": "^8.3.0",
    "rimraf": "^6.0.1",
    "@types/node": "^20.16.5"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  }
}