{
  "name": "@smc/api-client",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "generate": "node ./scripts/generate.mjs",
    "build": "tsup src/index.ts --format cjs --dts --clean --sourcemap",
    "typecheck": "tsc --noEmit -p .",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@smc/config-typescript": "workspace:*",
    "typescript": "^5.6.3",
    "tsup": "^8.3.0",
    "rimraf": "^6.0.1",
    "openapi-typescript": "^7.4.1"
  },
  "dependencies": {
    "@smc/contracts": "workspace:*",
    "openapi-fetch": "^0.13.4"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  }
}