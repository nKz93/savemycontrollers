  "info": {
    "title": "SaveMyControllers API",
    "description": "Contrat API du monolithe modulaire SaveMyControllers",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "smc_access_token"
      }
    },
    "schemas": {
      "MergeCartResponseDto": {
        "type": "object",
        "properties": {
          "merged": {
            "type": "boolean"
          },
          "cartId": {
            "type": "object",
            "nullable": true
          }
        },
        "required": [
          "merged"
        ]
      },
      "CreateOrderBodyDto": {
        "type": "object",
        "properties": {
          "cartId": {
            "type": "string"
          },
          "billingAddressId": {
            "type": "string"
          },
          "shippingAddressId": {
            "type": "string"
          }
        },
        "required": [
          "cartId",
          "billingAddressId",
          "shippingAddressId"
        ]
      },
      "OrderAddressSnapshotResponseDto": {
        "type": "object",
        "properties": {
          "recipientName": {
            "type": "string"
          },
          "companyName": {
            "type": "object",
            "nullable": true
          },
          "line1": {
            "type": "string"
          },
          "line2": {
            "type": "object",
            "nullable": true
          },
          "postalCode": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "phone": {
            "type": "object",
            "nullable": true
          }
        },
        "required": [
          "recipientName",
          "line1",
          "postalCode",
          "city",
          "country"
        ]
      },
      "OrderLineComponentResponseDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "priceMinor": {
            "type": "number"
          }
        },
        "required": [
          "name",
          "priceMinor"
        ]
      },
      "OrderItemDetailResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "deviceModelName": {
            "type": "string"
          },
          "deviceVariantName": {
            "type": "string"
          },
          "hardwareRevisionLabel": {
            "type": "object",
            "nullable": true
          },
          "reportedIssue": {
            "type": "object",
            "nullable": true
          },
          "unitPriceMinor": {
            "type": "number"
          },
          "discountMinor": {
            "type": "number"
          },
          "taxAmountMinor": {
            "type": "number"
          },
          "totalMinor": {
            "type": "number"
          },
          "services": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderLineComponentResponseDto"
            }
          },
          "options": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderLineComponentResponseDto"
            }
          },
          "repairCaseId": {
            "type": "object",
            "nullable": true
          }
        },
        "required": [
          "id",
          "deviceModelName",
          "deviceVariantName",
          "unitPriceMinor",
          "discountMinor",
          "taxAmountMinor",
          "totalMinor",
          "services",
          "options"
        ]
      },
      "OrderDetailResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "reference": {
            "type": "string"
          },
          "financialStatus": {
            "type": "object"
          },
          "operationalStatus": {
            "type": "object"
          },
          "billingAddress": {
            "$ref": "#/components/schemas/OrderAddressSnapshotResponseDto"
          },
          "shippingAddress": {
            "$ref": "#/components/schemas/OrderAddressSnapshotResponseDto"
          },
          "subtotalMinor": {
            "type": "number"
          },
          "discountMinor": {
            "type": "number"
          },
          "taxMinor": {
            "type": "number"
          },
          "shippingFeeMinor": {
            "type": "number"
          },
          "totalMinor": {
            "type": "number"
          },
          "currency": {
            "type": "string",
            "example": "EUR"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItemDetailResponseDto"
            }
