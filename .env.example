# ---------------------------------------------------------------------------
# Variables d'environnement — SaveMyControllers
# Copier ce fichier en .env (developpement) et ne jamais committer .env
# ---------------------------------------------------------------------------

NODE_ENV=development

# --- API ---
API_PORT=3001
API_URL=http://localhost:3001
# Meme valeur que API_URL en local, mais distincte car exposee au
# navigateur (prefixe NEXT_PUBLIC_ obligatoire pour Next.js) : les
# composants client de apps/web l'utilisent pour appeler l'API
# directement (credentials: "include"), tandis que les composants serveur
# utilisent API_URL et transmettent manuellement les cookies de la
# requete entrante (voir apps/web/lib/server-api-client.ts).
NEXT_PUBLIC_API_URL=http://localhost:3001
# COOKIE_DOMAIN volontairement laisse vide en local : un cookie sans
# attribut Domain reste valide pour l'hote exact (localhost), ce qui est
# le comportement souhaite. Ne jamais definir COOKIE_DOMAIN=localhost
# (le navigateur rejette ou traite differemment ce cas selon les versions).
COOKIE_DOMAIN=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# --- Frontends ---
WEB_PORT=3000
OPS_PORT=3002

# --- Base de donnees ---
DATABASE_URL=postgresql://smc:smc_dev_password@localhost:5432/smc_dev?schema=public
DATABASE_URL_TEST=postgresql://smc:smc_dev_password@localhost:5432/smc_test?schema=public

# --- Redis / BullMQ ---
REDIS_URL=redis://localhost:6379

# --- Stockage S3 compatible (MinIO en developpement) ---
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=eu-west-3
STORAGE_BUCKET=smc-dev
STORAGE_ACCESS_KEY_ID=smc_minio_access_key
STORAGE_SECRET_ACCESS_KEY=smc_minio_secret_key

# --- Email (Mailpit en developpement) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM="SaveMyControllers <no-reply@savemycontrollers.example>"

# --- Authentification ---
ACCESS_TOKEN_SECRET=change_me_access_token_secret_min_32_chars
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
JWT_ISSUER=savemycontrollers
JWT_AUDIENCE=savemycontrollers-api
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1
CSRF_SECRET=change_me_csrf_secret_min_32_chars

# --- Chiffrement applicatif (charges utiles sensibles de l'Outbox, voir ADR-016) ---
# Cle base64 de 32 octets (AES-256-GCM). Generer avec :
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PAYLOAD_ENCRYPTION_KEY=MVDJlnL3fGHqWTQ+7NpF7KU5tdeq9eLUd6VZs0O61fM=

# --- Reverse proxy ---
# Nombre de sauts de proxy de confiance devant l'API (0 en developpement
# local sans proxy). Determine comment Express interprete X-Forwarded-For.
TRUSTED_PROXY_COUNT=0

# --- Compte super-administrateur de seed (LOCAL UNIQUEMENT) ---
SEED_SUPERADMIN_EMAIL=admin@local.test
SEED_SUPERADMIN_PASSWORD=ChangeMe-Local-Only-1234!

# --- Observabilite ---
LOG_LEVEL=info
SENTRY_DSN=
