# Modele de configuration STAGING — copier vers .env.staging sur le
# serveur cible (JAMAIS commiter .env.staging lui-meme, deja dans
# .gitignore). Toutes les valeurs ci-dessous sont des EXEMPLES/placeholders
# a remplacer — aucune n'est un vrai secret.
#
# Regle absolue : ces secrets doivent etre DIFFERENTS de tout secret de
# production, generes independamment (voir commandes ci-dessous).

# --- Domaines ------------------------------------------------------------
# API_DOMAIN doit etre un SOUS-DOMAINE de STAGING_DOMAIN (necessaire pour
# que COOKIE_DOMAIN puisse etre partage entre les deux — voir plus bas).
STAGING_DOMAIN=staging.exemple.com
API_DOMAIN=api.staging.exemple.com
PUBLIC_API_URL=https://api.staging.exemple.com

# --- Registre d'images (voir .github/workflows/deploy-staging.yml) ------
IMAGE_REGISTRY=ghcr.io/VOTRE_UTILISATEUR_GITHUB/savemycontrollers
IMAGE_TAG=latest

# --- Base de donnees (jamais exposee publiquement, reseau Docker interne) -
POSTGRES_USER=smc_staging
# Generer avec : openssl rand -base64 24
POSTGRES_PASSWORD=CHANGEME_openssl_rand_base64_24
POSTGRES_DB=smc_staging

# --- Redis (jamais expose publiquement) -----------------------------------
# Generer avec : openssl rand -base64 24
REDIS_PASSWORD=CHANGEME_openssl_rand_base64_24

# --- Secrets applicatifs — TOUS DIFFERENTS de la production --------------
# Generer chacun independamment avec :
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
ACCESS_TOKEN_SECRET=CHANGEME_32_octets_min_genere_independamment
CSRF_SECRET=CHANGEME_32_octets_min_genere_independamment
# Doit decoder en EXACTEMENT 32 octets (voir env.schema.ts, verifie au
# demarrage) :
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
PAYLOAD_ENCRYPTION_KEY=CHANGEME_32_octets_exacts_genere_independamment

JWT_ISSUER=savemycontrollers-staging
JWT_AUDIENCE=savemycontrollers-staging-api

# --- Cookies, CORS, proxy de confiance ------------------------------------
# Domaine PARENT partage entre STAGING_DOMAIN et API_DOMAIN (avec le point
# initial) pour que le cookie de session soit envoye correctement aux deux.
COOKIE_DOMAIN=.staging.exemple.com
CORS_ALLOWED_ORIGINS=https://staging.exemple.com
# Caddy est le seul proxy en amont de l'API : un seul "hop" de confiance.
TRUSTED_PROXY_COUNT=1

# --- Donnees de demonstration (staging uniquement, jamais en prod) -------
NODE_ENV=production
SEED_DEMO_CATALOG=true
# Optionnel : compte super-administrateur de demonstration pour le
# staging (laisser vide pour ne pas en creer).
SEED_SUPERADMIN_EMAIL=
SEED_SUPERADMIN_PASSWORD=

# --- Email (aucun envoi reel en staging — voir docs/deployment/staging.md) -
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM="SaveMyControllers Staging <staging@exemple.com>"

# --- Stockage de fichiers (non utilise par le parcours actuel, requis par
# le schema — placeholders suffisants tant qu'aucun upload n'est actif) ---
STORAGE_ENDPOINT=https://staging-storage.invalid
STORAGE_REGION=eu-west-3
STORAGE_BUCKET=smc-staging
STORAGE_ACCESS_KEY_ID=placeholder
STORAGE_SECRET_ACCESS_KEY=placeholder

# --- Divers ---------------------------------------------------------------
LOG_LEVEL=info
# Seuil de debit standard (production) : le staging n'a pas les volumes
# de requetes d'une suite de tests automatisee, contrairement a
# .github/workflows/e2e.yml qui, lui, releve ce seuil.
THROTTLE_LIMIT_PER_MINUTE=120

# --- Protection optionnelle de l'ensemble du staging (voir infra/Caddyfile) -
# Laisser vide pour un acces public sans mot de passe.
STAGING_BASIC_AUTH_USER=
STAGING_BASIC_AUTH_HASH=

# --- Paiement --------------------------------------------------------------
# AUCUNE cle Stripe ici. Le parcours de paiement n'est pas encore
# implemente (voir rapport de phase) — ne pas ajouter de cle avant
# validation explicite.
