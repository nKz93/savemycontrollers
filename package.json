{
  "name": "savemycontrollers",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "typecheck": "turbo run typecheck",
    "db:format": "pnpm --filter @smc/database exec prisma format --schema ../../prisma/schema.prisma",
    "db:generate": "pnpm --filter @smc/database generate",
    "db:validate": "pnpm --filter @smc/database validate",
    "db:migrate": "pnpm --filter @smc/database migrate",
    "db:migrate:deploy": "pnpm --filter @smc/database migrate:deploy",
    "db:seed": "pnpm --filter @smc/database seed",
    "clean": "turbo run clean && rimraf node_modules",
    "verify:entrypoints": "node infra/scripts/verify-package-entrypoints.mjs",
    "verify:phase2c2": "pnpm db:format && pnpm db:validate && pnpm db:generate && pnpm lint && pnpm typecheck && pnpm test:unit && pnpm test:integration && pnpm build && pnpm verify:entrypoints && pnpm --filter @smc/api openapi:generate && pnpm --filter @smc/api-client generate"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "rimraf": "^6.0.1",
    "prettier": "^3.3.3",
    "eslint": "^9.13.0",
    "@smc/eslint-config": "workspace:*",
    "tsup": "^8.3.0",
    "prisma": "5.22.0"
  },
  "packageManager": "pnpm@9.15.9",
  "type": "module"
}